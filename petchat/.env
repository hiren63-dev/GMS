# Committed, non-secret build flags. Real secrets (Firebase keys) live in .env.local (gitignored).
# VITE_AI_ENABLED gates the LLM chat brain. It is INLINED at build time by Vite —
# it must be true when `npm run build` runs, NOT just in Vercel's dashboard, because
# Vercel serves the prebuilt GMS-deploy/ folder rather than building from source.
VITE_AI_ENABLED=true
