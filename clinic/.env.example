# Paste the private_key from your service account JSON.
# Keep the quotes. Replace \n with literal \n (not newlines).
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
# The doctor's Google Calendar ID (usually their Gmail address)
GOOGLE_CALENDAR_ID=doctor@gmail.com

# ── Cron job security ─────────────────────────────────────────────
# Generate any random string: openssl rand -hex 32
CRON_SECRET=replace_with_a_random_secret_string
